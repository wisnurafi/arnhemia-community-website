# Supabase project URL (e.g. https://abc.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — SERVER ONLY, never commit or expose
# Used for admin tasks like seeding the first owner account and looking up
# recipient emails when sending transactional alert emails.
SUPABASE_SERVICE_ROLE_KEY=

# MailerSend API key — SERVER ONLY, never commit or expose
MAILERSEND_API_KEY      = 
MAILERSEND_FROM         = 
MAILERSEND_FROM_NAME    = 
APP_URL                 = http://localhost:3000